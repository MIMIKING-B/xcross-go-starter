# =============================================================================
# GoFrame CLI 工具管理
# =============================================================================
# 作用：
#   本文件负责 GoFrame CLI（gf 命令行工具）的安装和自动检测。
#   gf 是 GoFrame 框架的核心命令行工具，提供代码生成、编译构建、数据库操作等功能。
#
# 为什么单独放在 hack-cli.mk？
#   将 CLI 工具管理独立出来，方便多个项目复用，也便于统一升级和维护。
#
# 常用命令：
#   make cli         → 手动下载并安装最新版 gf CLI
#   make cli.install → 自动检测 gf 是否已安装，未安装则自动调用 make cli
# =============================================================================

# -----------------------------------------------------------------------------
# 手动安装/更新 gf CLI 到最新稳定版
# 原理：
#   1. 根据当前操作系统 (GOOS) 和架构 (GOARCH) 下载对应的 gf 二进制文件
#   2. 赋予执行权限并安装到系统 PATH
#   3. 删除临时下载文件
# 示例：macOS + ARM64 → gf_darwin_arm64
# -----------------------------------------------------------------------------
.PHONY: cli
cli:
	@set -e; \
	wget -O gf \
	https://github.com/gogf/gf/releases/latest/download/gf_$(shell go env GOOS)_$(shell go env GOARCH) && \
	chmod +x gf && \
	./gf install -y && \
	rm ./gf


# -----------------------------------------------------------------------------
# 自动检测并安装 gf CLI
# 原理：
#   1. 尝试执行 gf -v 检查是否已安装
#   2. 如果未安装（命令不存在），自动调用上方的 make cli 进行安装
#   3. 其他 Makefile 中的命令（如 make build / make dao）都会依赖此目标
#
# 使用场景：
#   新成员克隆项目后第一次运行 make build，会自动为其安装 gf 工具
# -----------------------------------------------------------------------------
.PHONY: cli.install
cli.install:
	@set -e; \
	gf -v > /dev/null 2>&1 || if [[ "$?" -ne "0" ]]; then \
  		echo "GoFrame CLI 未安装，开始自动安装..."; \
		make cli; \
	fi;